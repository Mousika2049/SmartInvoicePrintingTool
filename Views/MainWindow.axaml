<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SmartInvoicePrintingTool.ViewModels"
        x:Class="SmartInvoicePrintingTool.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Smart Invoice Printing Tool"
        Width="600" Height="550"
        WindowStartupLocation="CenterScreen">
    
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid Margin="20,10" RowDefinitions="Auto,Auto,Auto,*,Auto">
        
        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="智能票据合并打印工具" FontWeight="Bold" FontSize="20" Margin="0,0,0,15" />

        <!-- 源文件夹 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="源 PDF 目录：" VerticalAlignment="Center" Width="90" />
            <TextBox Text="{Binding SourcePath}" IsReadOnly="True" HorizontalAlignment="Stretch" Margin="0,0,10,0" />
            <Button Content="选择..." Command="{Binding BrowseSourceCommand}" Width="60" />
        </StackPanel>

        <!-- 输出文件夹 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="输出 PDF 目录：" VerticalAlignment="Center" Width="90" />
            <TextBox Text="{Binding OutputPath}" IsReadOnly="True" HorizontalAlignment="Stretch" Margin="0,0,10,0" />
            <Button Content="选择..." Command="{Binding BrowseOutputCommand}" Width="60" />
        </StackPanel>

        <!-- 打印机与操作按钮 -->
        <StackPanel Grid.Row="3" Margin="0,10">
            <!-- 打印机选择 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="目标打印机：" VerticalAlignment="Center" Width="90" />
                <ComboBox ItemsSource="{Binding Printers}" 
                         SelectedItem="{Binding SelectedPrinter}"
                         HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- 进度条与状态 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" HorizontalAlignment="Stretch" />
                <Button Content="▶ 开始处理" 
                        Command="{Binding StartProcessingCommand}" 
                        IsEnabled="{Binding !IsBusy}" 
                        Margin="10,0,0,0" Width="100" />
                <Button Content="⏹ 停止" Command="{Binding StopProcessingCommand}" IsEnabled="{Binding IsCancellable}" Margin="10,0" Width="80" />
            </StackPanel>
            
            <ProgressBar Value="{Binding ProgressValue}" Height="20" Margin="0,5" />
            
            <!-- 日志显示区 -->
            <TextBlock Text="处理日志:" FontWeight="Bold" Margin="0,20,0,5" />
            <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                <TextBox Text="{Binding LogContent}" IsReadOnly="True" AcceptsReturn="True" 
                        FontFamily="Consolas" TextWrapping="Wrap" Background="#F5F5F5" />
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Window>