<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SmartInvoicePrintingTool.ViewModels"
        x:Class="SmartInvoicePrintingTool.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Smart Invoice Printing Tool"
        Width="750" Height="600"
        Background="{DynamicResource SystemFillColorSecondaryBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <!-- 定义一些图标资源 -->
    <Window.Styles>
        <Style Selector="Button.command-btn">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="15,8" />
        </Style>
    </Window.Styles>

    <Border Margin="20" Padding="20" CornerRadius="12" 
            Background="{DynamicResource SystemFillColorSurfaceBrush}"
            BoxShadow="0 4 10 0 #20000000">
        
        <StackPanel Spacing="20">
            
            <!-- 1. 标题区 -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="🖨️" FontSize="32" VerticalAlignment="Center" />
                <StackPanel>
                    <TextBlock Text="Smart Invoice Printing Tool" FontWeight="SemiBold" FontSize="20" />
                    <TextBlock Text="基于 Avalonia Fluent UI 设计" Foreground="{DynamicResource SystemControlDisabledForegroundBrush}" FontSize="12" />
                </StackPanel>
            </StackPanel>

            <Separator />

            <!-- 2. 路径选择区 (卡片风格) -->
            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="10" ColumnSpacing="10">
                <!-- 源路径 -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📂" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBox Text="{Binding SourcePath}" PlaceholderText="点击右侧按钮选择源文件夹" IsReadOnly="True" VerticalAlignment="Center" Width="400" />
                </StackPanel>
                <Button Grid.Row="0" Grid.Column="1" Content="浏览源目录" Command="{Binding BrowseSourceCommand}" 
                        Classes="command-btn" HorizontalAlignment="Right" />

                <!-- 输出路径 -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📥" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBox Text="{Binding OutputPath}" PlaceholderText="点击右侧按钮选择输出目录" IsReadOnly="True" VerticalAlignment="Center" Width="400" />
                </StackPanel>
                <Button Grid.Row="1" Grid.Column="1" Content="浏览输出目录" Command="{Binding BrowseOutputCommand}" 
                        Classes="command-btn" HorizontalAlignment="Right" />
            </Grid>

            <!-- 3. 打印机与操作区 -->
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Spacing="5">
                    <TextBlock Text="选择打印机" FontWeight="SemiBold" Margin="0,0,0,5" />
                    <ComboBox ItemsSource="{Binding Printers}" 
                              SelectedItem="{Binding SelectedPrinter}"
                              PlaceholderText="选择目标打印机" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="10">
                    <Button Content="▶ 开始合并并打印" 
                            Command="{Binding StartProcessingCommand}" 
                            IsEnabled="{Binding !IsBusy}"
                            Classes="command-btn" 
                            HorizontalAlignment="Stretch" />
                    
                    <Button Content="⏹ 强制停止" 
                            Command="{Binding StopProcessingCommand}" 
                            IsEnabled="{Binding IsCancellable}"
                            Theme="{StaticResource FlatButtonTheme}"
                            Foreground="Red"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
            </Grid>

            <!-- 4. 进度与状态 -->
            <StackPanel Spacing="5">
                <Grid ColumnDefinitions="*, Auto">
                    <ProgressBar Value="{Binding ProgressValue}" Height="8" CornerRadius="4" />
                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource SystemControlForegroundBrush}" />
                </Grid>
            </StackPanel>

            <!-- 5. 实时日志 -->
            <StackPanel Spacing="5">
                <TextBlock Text="运行日志" FontWeight="SemiBold" />
                <TextBox Text="{Binding LogContent}" 
                         IsReadOnly="True" 
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="150"
                         CornerRadius="8"
                         Padding="10"
                         Background="#101010"
                         Foreground="#00FF00"
                         FontFamily="Consolas"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>